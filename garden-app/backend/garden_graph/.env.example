# Required: At least one model provider API key is required
# Uncomment and set your API keys below

# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
# GOOGLE_API_KEY=your_google_key_here
# GROQ_API_KEY=your_groq_key_here
# OPENROUTER_API_KEY=your_openrouter_key_here

# Optional settings
# DISABLE_COST_TRACKING=false  # Set to true to disable cost tracking
# BUDGET_LIMIT=1.0  # USD budget limit before warnings
# ROUTER_MODEL=gpt-3.5-turbo  # Model to use for routing decisions
