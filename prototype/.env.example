# 🌱 Garden World Chat – Example Environment File
# Copy this file to `.env` at the root of `prototype/` and fill in the values.
# The application will automatically load variables from this location.

# -------------------------------------------------
# 🔑 Model Provider API Keys (at least one required)
# -------------------------------------------------
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# ------------------------
# 💾 Persistence Back-End
# ------------------------
# Select storage backend: "json" (local flat-file) or "supabase" (remote Postgres)
STORAGE_BACKEND=json

# Supabase connection (required only when STORAGE_BACKEND=supabase)
# Obtain these in Supabase → Settings → API
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=

# ------------------
# 🧠 Memory Settings
# ------------------
# Minimum importance required to save a message as a memory (0–1)
MEM_SIGNIFICANCE_THRESHOLD=0.25
# Threshold for emotional impact amplification / forgiveness
EMOTIONAL_IMPACT_THRESHOLD=0.5

# ---------------------------------
# 🎓 Supervisor / Producer Thresholds
# ---------------------------------
PROMPT_REFRESH_ENERGY_THRESHOLD=8.0
HIGHLIGHT_IMPACT_THRESHOLD=1.0

# ------------------------
# 💸 Cost-Tracking Options
# ------------------------
DISABLE_COST_TRACKING=false
BUDGET_LIMIT=20.0       # USD

# Model used by the router LLM
ROUTER_MODEL=gpt-4o-mini

# (Add any additional variables below)
